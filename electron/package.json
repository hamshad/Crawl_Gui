{
  "name": "coleoptera",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite build && electron .",
    "dev:skip-build": "electron .",
    "build": "vite build",
    "build:python": "cd .. && .venv/bin/pyinstaller --onefile --name backend-server --distpath electron/python-bin --add-data \".venv/lib/python3.12/site-packages/crawl4ai:crawl4ai\" backend.py",
    "build:python:copy-browsers": "rm -rf playwright-browsers && mkdir -p playwright-browsers && cp -R \"$HOME/Library/Caches/ms-playwright/chromium-1208\" playwright-browsers/ && cp -R \"$HOME/Library/Caches/ms-playwright/ffmpeg-1011\" playwright-browsers/",
    "build:python:all": "npm run build:python && npm run build:python:copy-browsers",
    "build:electron": "npm run build && npm run build:python:all && electron-builder",
    "build:electron:quick": "npm run build && electron-builder",
    "build:all": "npm run build && npm run build:python:all && electron-builder",
    "preview": "vite preview",
    "start": "electron ."
  },
  "author": "",
  "license": "ISC",
  "description": "Coleoptera - Web to Markdown Desktop App",
  "build": {
    "appId": "com.coleoptera.desktop",
    "productName": "Coleoptera",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "index.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python-bin",
        "to": "python-bin",
        "filter": ["**/*"]
      },
      {
        "from": "playwright-browsers",
        "to": "playwright-browsers",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Utility"
    },
    "win": {
      "target": ["nsis"],
      "artifactName": "${productName}-${version}-win-x64.${ext}"
    }
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@phosphor-icons/react": "^2.1.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  }
}
